# .skaroignore — files excluded from LLM analysis during `skaro init`
# Syntax is identical to .gitignore.
# Add paths that contain sensitive, private, or irrelevant content.
#
# Run `skaro init` (option B) to see which files will be excluded.

# ── Secrets & credentials ──────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.*
credentials.*
*_secret*
*_credentials*
*_token*
auth.json
service-account*.json

# ── Private data & dumps ───────────────────────────────────────────────────
*.sql
*.dump
*.db
*.sqlite
*.sqlite3
data/
datasets/
fixtures/private/
backups/
exports/

# ── Generated & vendored code ──────────────────────────────────────────────
vendor/
third_party/
generated/
auto_generated/
__generated__/
*.pb.go
*.pb.ts

# ── Large binary assets ────────────────────────────────────────────────────
assets/
media/
uploads/
storage/
public/images/
public/videos/

# ── Logs & telemetry ───────────────────────────────────────────────────────
logs/
*.log
*.trace

# ── IDE & OS files ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
